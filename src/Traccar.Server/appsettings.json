{
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss} [{Level:u3}] {SourceContext}: {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/traccar-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 7,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss} [{Level:u3}] {SourceContext}: {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [ "FromLogContext" ]
  },
  "AllowedHosts": "*",

  "ConnectionStrings": {
    "DefaultConnection": "Server=localhost;Database=fleet;User Id=postgres;Password=root;"
  },

  "Database": {
    "MaxConcurrentConnections": 80,
    "Retry": {
      "Enable": true,
      "MaxRetryCount": 6,
      "MaxRetryDelaySeconds": 30,
      "CommandTimeoutSeconds": 30
    }
  },

  "Admin": {
    "Email": "admin",
    "Password": "admin"
  },
  "Geocoder": {
    "Type": "nominatim",
    "Url": "http://31.220.94.66:8080"
  },
  "Jwt": {
    "Issuer": "traccar",
    "Audience": "traccar-clients",
    "AccessTokenLifetimeSeconds": 3600,
    "RefreshTokenLifetimeDays": 30
  },
  "Report": {
    "PeriodLimit": 0,
    "FastThreshold": 86400,
    "Trip": {
      "MinimalDistance": 500,
      "MinimalDuration": 300,
      "MinimalParking": 300,
      "MinimalNoData": 3600,
      "UseIgnition": false,
      "IgnoreOdometer": false
    }
  },
  "Server": {
    "Timeout": 1800,
    "WebUrl": "http://localhost:5090"
  },
  "Protocols": {
    "h02":       { "Port": 5013 },
    "gt06":      { "Port": 5023 },
    "khd":       { "Port": 5021 },
    "gosafe":    { "Port": 5165 },
    "gl200":     { "Port": 5093 },
    "teltonika": { "Port": 5027 },
    "jt1078":    { "Port": 5076 },
    "jt808":     { "Port": 5083 },
    "niot":      { "Port": 5048 },
    "meitrack":  { "Port": 5012 },
    "meiligao":  { "Port": 7700 },
    "starcom":   { "Port": 5501 }
  }
}
