{
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss} [{Level:u3}] {SourceContext}: {Message:lj}{NewLine}{Exception}"
        }
      },
      {
        "Name": "File",
        "Args": {
          "path": "logs/traccar-.log",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 7,
          "outputTemplate": "{Timestamp:yyyy-MM-dd HH:mm:ss} [{Level:u3}] {SourceContext}: {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": [ "FromLogContext" ]
  },
  "AllowedHosts": "*",
  "Admin": {
    "Email": "admin",
    "Password": "admin"
  },
  "Server": {
    "Timeout": 1800,
    "WebUrl": "http://localhost:5090"
  },
  "Protocols": {
    "h02":       { "Port": 5013 },
    "gt06":      { "Port": 5023 },
    "khd":       { "Port": 5021 },
    "gosafe":    { "Port": 5165 },
    "gl200":     { "Port": 5093 },
    "teltonika": { "Port": 5027 },
    "jt1078":    { "Port": 5076 },
    "jt808":     { "Port": 5083 },
    "niot":      { "Port": 5048 },
    "meitrack":  { "Port": 5012 },
    "meiligao":  { "Port": 7700 }
  }
}
